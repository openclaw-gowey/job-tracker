# JobTracker Server - Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=3002

# PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# Discord OAuth (get these from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3002/auth/discord/callback

# CORS & Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Session (generate a random string for production)
SESSION_SECRET=dev_secret_change_in_production